<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF0F0"
    android:padding="24dp">

    <TextView
        android:id="@+id/lbl_post_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Post Title"
        android:textColor="#3E2723"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"/>

    <EditText
        android:id="@+id/et_post_title"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/lbl_post_title"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_edittext"
        android:hint="Type a title..."
        android:paddingStart="16dp"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/lbl_post_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/et_post_title"
        android:layout_marginTop="20dp"
        android:text="Post Content"
        android:textColor="#3E2723"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_post_description"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_below="@id/lbl_post_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_edittext"
        android:gravity="top"
        android:hint="Share your beauty secrets.."
        android:padding="16dp"
        android:textSize="16sp" />

    <ImageView
        android:id="@+id/iv_selected_image"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_below="@id/et_post_description"
        android:layout_marginTop="12dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="@drawable/rounded_edittext"
        android:clipToOutline="true" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_pick_image"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/iv_selected_image"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:text="Add Photo 📷"
        android:textColor="#D86B8C"
        app:strokeColor="#D86B8C"
        app:cornerRadius="15dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_submit_post"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:text="Submit Post"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:backgroundTint="#D86B8C"
        app:cornerRadius="30dp" />

</RelativeLayout>