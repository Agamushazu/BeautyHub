<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <include layout="@layout/app_logo_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal Information"
            android:textSize="22sp"
            android:textColor="#3E2723"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:textStyle="bold"/>

        <!-- PHOTO ANALYSIS SECTION -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="15dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFF5F5">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Fill with Photo"
                    android:textColor="#A64452"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload a selfie and we'll analyze your features!"
                    android:textColor="#7D7D7D"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"
                    android:textAlignment="center"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upload_photo"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPLOAD PHOTO"
                    app:strokeColor="#D36B6B"
                    android:textColor="#D36B6B"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconTint="#D36B6B" />
                    
                <ProgressBar
                    android:id="@+id/analysis_progress"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:visibility="gone"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- EYES SECTION -->
                <TextView 
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="EYES" 
                    android:textColor="#A64452" 
                    android:textStyle="bold"
                    android:textSize="13sp"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Eye Color:" android:textColor="#7D7D7D" android:textSize="14sp"/>
                <Spinner 
                    android:id="@+id/spinner_eye_color" 
                    android:layout_width="match_parent" 
                    android:layout_height="45dp" 
                    android:layout_marginBottom="16dp" 
                    android:background="@android:drawable/btn_dropdown"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Eye Shape:" android:textColor="#7D7D7D" android:textSize="14sp"/>
                <Spinner 
                    android:id="@+id/spinner_eye_shape" 
                    android:layout_width="match_parent" 
                    android:layout_height="45dp" 
                    android:layout_marginBottom="24dp" 
                    android:background="@android:drawable/btn_dropdown"/>

                <!-- FACE & COMPLEXION SECTION -->
                <TextView 
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="FACE &amp; COMPLEXION" 
                    android:textColor="#A64452" 
                    android:textStyle="bold"
                    android:textSize="13sp"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Skin Tone:" android:textColor="#7D7D7D" android:textSize="14sp"/>
                <Spinner 
                    android:id="@+id/spinner_skin_tone" 
                    android:layout_width="match_parent" 
                    android:layout_height="45dp" 
                    android:layout_marginBottom="16dp" 
                    android:background="@android:drawable/btn_dropdown"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Face Shape:" android:textColor="#7D7D7D" android:textSize="14sp"/>
                <Spinner 
                    android:id="@+id/spinner_face_shape" 
                    android:layout_width="match_parent" 
                    android:layout_height="45dp" 
                    android:layout_marginBottom="16dp" 
                    android:background="@android:drawable/btn_dropdown"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Eyebrows Shape:" android:textColor="#7D7D7D" android:textSize="14sp"/>
                <Spinner 
                    android:id="@+id/spinner_eyebrows_shape" 
                    android:layout_width="match_parent" 
                    android:layout_height="45dp" 
                    android:layout_marginBottom="24dp" 
                    android:background="@android:drawable/btn_dropdown"/>

                <!-- LIPS & HAIR SECTION -->
                <TextView 
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="LIPS &amp; HAIR" 
                    android:textColor="#A64452" 
                    android:textStyle="bold"
                    android:textSize="13sp"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lips Size:" android:textColor="#7D7D7D" android:textSize="14sp"/>
                <Spinner 
                    android:id="@+id/spinner_lips_size" 
                    android:layout_width="match_parent" 
                    android:layout_height="45dp" 
                    android:layout_marginBottom="16dp" 
                    android:background="@android:drawable/btn_dropdown"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hair Color:" android:textColor="#7D7D7D" android:textSize="14sp"/>
                <Spinner 
                    android:id="@+id/spinner_hair_color" 
                    android:layout_width="match_parent" 
                    android:layout_height="45dp" 
                    android:layout_marginBottom="24dp" 
                    android:background="@android:drawable/btn_dropdown"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_info"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="SAVE INFORMATION"
                    android:backgroundTint="#D36B6B"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_goback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="16dp"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:backgroundTint="#D86B8C"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textStart" />

    </LinearLayout>
</ScrollView>
