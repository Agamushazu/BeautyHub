<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF0F0"
    tools:context=".ProfileActivity">

    <RelativeLayout
        android:id="@+id/profile_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="PROFILE"
            android:textColor="#3E2723"
            android:textSize="22sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sign_out"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:backgroundTint="#A64452"
            android:text="Logout"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_logout_custom"
            app:iconTint="#FFFFFF" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_user_profile_pic"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginBottom="32dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_camera"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="#A64452"
            app:strokeWidth="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_personal_info"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#F4C2C2"
            android:text="PERSONAL INFORMATION"
            android:textColor="#3E2723"
            android:textSize="14sp"
            app:cornerRadius="15dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_collection"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#FFF9E3"
            android:text="PRODUCT COLLECTION"
            android:textColor="#3E2723"
            android:textSize="14sp"
            app:cornerRadius="15dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_favorites"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:backgroundTint="#E3F2FD"
            android:text="MY FAVORITES"
            android:textColor="#3E2723"
            android:textSize="14sp"
            app:cornerRadius="15dp" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:elevation="8dp"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>