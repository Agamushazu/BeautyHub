<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FDF0F0">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="4dp"
        app:strokeWidth="1dp"
        app:strokeColor="#EEEEEE">

        <ImageView
            android:id="@+id/iv_dialog_product_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:background="#FFFFFF" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_dialog_product_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#A64452"
        android:layout_marginBottom="4dp"
        android:text="Product Name" />

    <TextView
        android:id="@+id/tv_dialog_product_brand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="italic"
        android:textColor="#777777"
        android:layout_marginBottom="16dp"
        android:text="Brand Name" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="150dp">

        <TextView
            android:id="@+id/tv_dialog_product_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp"
            android:text="Description goes here..." />
    </ScrollView>

</LinearLayout>